---
layout: layouts/base.njk
---

{% set previousPost = collections.blogPosts | getPreviousCollectionItem %}
{% set nextPost = collections.blogPosts | getNextCollectionItem %}

<article class="post">
  <header>
    <h1>{{ title }}</h1>
    <p class="post-meta">
      <time datetime="{{ page.date | htmlDateString }}">{{ page.date | readableDate }}</time>
    </p>
  </header>
  <div class="prose">
    {{ content | safe }}
  </div>
  {% if previousPost or nextPost %}
  <nav class="post-nav" aria-label="Post navigation">
    {% if previousPost %}
      <a href="{{ previousPost.url }}" class="post-nav__prev">← {{ previousPost.data.title }}</a>
    {% endif %}
    {% if nextPost %}
      <a href="{{ nextPost.url }}" class="post-nav__next">{{ nextPost.data.title }} →</a>
    {% endif %}
  </nav>
  {% endif %}
</article>
